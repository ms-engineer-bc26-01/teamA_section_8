# ==============================================================
# .env.example
# 実際の .env には下記の値を埋めて使用する(.env はコミット禁止)
# API キー本体は メンバーC(インフラ・テスト担当) から DM で受領
# ==============================================================

# ----- OpenAI API -----
# 開発中は gpt-4o-mini、デモ/本番で gpt-4o に切替
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.7

# ----- Google Maps / Places API -----
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ----- Web検索API (Brave Search or Serper) -----
SEARCH_PROVIDER=brave
SEARCH_API_KEY=your_search_api_key_here

# ----- OpenWeatherMap -----
OPENWEATHER_API_KEY=your_openweather_key_here

# ----- Connpass (認証不要のためKey不要・UA指定のみ必須) -----
CONNPASS_USER_AGENT=SelfCareApp/1.0 (contact: your_email@example.com)

# ----- PostgreSQL -----
# docker-compose 内の db サービス名でホスト指定
DATABASE_URL=postgresql://postgres:password@db:5432/selfcare_db

# ----- 認証 -----
# 本番用は下記コマンドで生成: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ----- サーバ設定 -----
PORT=8000
NODE_ENV=development
TZ=Asia/Tokyo
# ローカル開発時のフロントエンドURL(CORS許可対象)
FRONTEND_URL=http://localhost:3000

# ----- レート制限(express-rate-limit) -----
# チャットAPIは1分あたり20回まで等でコスト暴発を防止
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ----- 会話履歴の件数制限(トークン溢れ防止) -----
CHAT_HISTORY_MESSAGE_LIMIT=10
