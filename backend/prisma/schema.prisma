// ==============================================================
// Prisma Schema
// --------------------------------------------------------------
// ポイント:
//  - binaryTargets に debian/alpine 両方を指定し、
//    ローカル(Mac/Win/Linux)と Docker コンテナのどちらでも動くように
//  - すべての timestamp を timestamptz(UTC保存) に統一
//  - gen_random_uuid() を使うため pgcrypto 拡張が必要
//    (init.sql で CREATE EXTENSION 済み)
// ==============================================================

generator client {
  provider      = "prisma-client-js"
  // Docker(debian-slim/OpenSSL3)、Alpine フォールバック、開発者ローカルの native
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== Users ==========
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255) // bcryptjs ハッシュ
  displayName  String   @map("display_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversations Conversation[]
  emotionLogs   EmotionLog[]

  @@map("users")
}

// ========== Conversations (会話セッション) ==========
model Conversation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  startedAt     DateTime @default(now()) @map("started_at") @db.Timestamptz(6)
  lastMessageAt DateTime @default(now()) @map("last_message_at") @db.Timestamptz(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, lastMessageAt])
  @@map("conversations")
}

// ========== Messages (会話メッセージ) ==========
model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           Role     // enum化で型安全に
  content        String   @db.Text
  emotionScore   Json?    @map("emotion_score") @db.JsonB  // {label, score, categories}
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum Role {
  user
  assistant
  system
}

// ========== EmotionLog (日次感情サマリー) ==========
model EmotionLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  logDate         DateTime @map("log_date") @db.Date
  dominantEmotion String?  @map("dominant_emotion") @db.VarChar(50)
  sentimentScore  Decimal? @map("sentiment_score") @db.Decimal(4, 3)
  summary         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate]) // 1ユーザー1日1レコード
  @@index([userId, logDate])
  @@map("emotion_logs")
}
