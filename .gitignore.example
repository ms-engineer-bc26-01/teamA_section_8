# ==============================================================
# .gitignore (リポジトリルート用)
# .gitignore.example をリネーム or 内容をコピーして使用
# ==============================================================

# ===== 環境変数 (最重要) =====
.env
.env.local
.env.*.local
!.env.example

# ===== Node.js =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== ビルド成果物 =====
dist/
build/
.next/
out/

# ===== IDE / OS =====
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
.DS_Store
Thumbs.db

# ===== TypeScript =====
*.tsbuildinfo

# ===== Prisma =====
# スキーマとマイグレーションはコミットする(除外しない)
# prisma/migrations/ はチーム共有するため含める

# ===== テスト =====
coverage/
.nyc_output/

# ===== ログ =====
*.log
logs/

# ===== Docker =====
# docker volume の中身は自動で除外される
